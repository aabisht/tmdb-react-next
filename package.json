{
  "name": "tmdb-react-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "check-types": "tsc --pretty --noEmit",
    "check-format": "prettier --check .",
    "check-lint": "eslint . --ext ts --ext tsx --ext js --fix",
    "format": "prettier --write .",
    "test-all": "npm run check-format && npm run check-lint && npm run check-types",
    "prepare": "husky install",
    "server": "concurrently \"npm run dev\" \"npm run api\"",
    "test": "jest --clearCache && jest --runInBand",
    "test:ci": "jest --ci"
  },
  "dependencies": {
    "@material-design-icons/font": "^0.14.13",
    "@reduxjs/toolkit": "^1.9.7",
    "@tailwindcss/line-clamp": "^0.4.4",
    "axios": "^1.6.0",
    "formik": "^2.4.5",
    "i18next": "latest",
    "next": "^14.2.5",
    "next-auth": "latest",
    "next-i18next": "latest",
    "next-redux-wrapper": "^8.1.0",
    "primereact": "^10.0.3",
    "react": "latest",
    "react-dom": "latest",
    "react-i18next": "latest",
    "react-redux": "^8.1.3",
    "react-slick": "^0.29.0",
    "slick-carousel": "^1.8.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.10",
    "@testing-library/jest-dom": "^5.16.4",
    "@testing-library/react": "^13.1.1",
    "@testing-library/user-event": "^14.1.1",
    "@types/jest": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "^18.0.0",
    "@types/react-slick": "^0.23.12",
    "@types/redux-mock-store": "latest",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "autoprefixer": "latest",
    "babel-jest": "latest",
    "concurrently": "latest",
    "cross-env": "latest",
    "eslint": "latest",
    "eslint-config-google": "latest",
    "eslint-config-next": "latest",
    "eslint-config-prettier": "latest",
    "eslint-config-standard": "latest",
    "eslint-plugin-import": "latest",
    "eslint-plugin-node": "latest",
    "eslint-plugin-promise": "latest",
    "eslint-plugin-react": "latest",
    "eslint-plugin-testing-library": "latest",
    "husky": "^7.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "latest",
    "jest-environment-jsdom": "latest",
    "postcss": "^8.4.31",
    "prettier": "latest",
    "redux-mock-store": "latest",
    "tailwindcss": "latest",
    "ts-jest": "latest",
    "ts-node-dev": "latest",
    "typescript": "latest"
  }
